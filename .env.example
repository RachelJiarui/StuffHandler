# Copy to .env and fill in. Loaded automatically by both process.py and the
# gallery website.

# Processing pipeline — required unless you run with --skip-enhance.
# The website's "Clean up with AI" upload option needs it too.
OPENAI_API_KEY=

# Gallery website — data lives in Firestore, authenticated via
# Application Default Credentials (gcloud auth application-default login).
#PHOTOS_DIR=done_output
#UPLOADS_DIR=uploads
GCP_PROJECT=stuff-handler-app
#PORT=8000
#UPLOAD_WORKERS=3

# Shared-password gate — leave both blank to disable (fine for local/LAN
# use). Required together if set; SITE_PASSWORD is what visitors type,
# SECRET_KEY signs the remember-this-device cookie (must stay fixed across
# restarts/workers or sessions randomly invalidate). Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#SITE_PASSWORD=
#SECRET_KEY=
# Cookie requires HTTPS by default; set to false only to test the login
# flow over plain HTTP on localhost/LAN.
#COOKIE_SECURE=true
